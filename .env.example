# Copy to .env and fill in. NOTHING here is required for the Phase 0.5 historical
# backtest against free APIs (GeckoTerminal / DexScreener / RugCheck / Jupiter need no key).

# --- Telegram MCP (chigwell/telegram-mcp) — lets me READ your channel history (Phase 0.5) ---
# These are consumed by the MCP server itself (its own env), not by memebot directly.
#   1) Get api_id / api_hash at https://my.telegram.org/apps
#   2) Clone https://github.com/chigwell/telegram-mcp and run:  uv run session_string_generator.py
#      (supports --qr or --phone). Save the printed session string.
#   3) Set TELEGRAM_EXPOSED_TOOLS=read-only — we only read; smallest blast radius.
# The account must have JOINED the signal channel. The session string == FULL account access.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_EXPOSED_TOOLS=read-only

# --- Production Telethon ingester (Phase 2+, the 24/7 service memebot runs itself) ---
# Separate from the MCP. Uses a FILE-based session named <TG_SESSION_NAME>.session, which
# caches the login so you authenticate once. That .session file is gitignored and sensitive
# (it is full access to the account). This is what TG_SESSION_NAME refers to.
TG_API_ID=
TG_API_HASH=
TG_SESSION_NAME=memebot
TG_CHANNELS=          # comma-separated @usernames or numeric ids

# --- Optional paid / keyed data (denser OHLCV, holders, higher rate limits) ---
BIRDEYE_API_KEY=
HELIUS_API_KEY=
JUPITER_API_KEY=      # blank = keyless lite-api.jup.ag (~1 req/s); set to use api.jup.ag

# --- Live execution (Phase 5+ only; use a BURNER wallet, NEVER a main key) ---
SOLANA_RPC_URL=
WALLET_PRIVATE_KEY=

# --- Live engine + dashboard ---
MEMEBOT_CHANNEL=@your_channel     # the TG call group/channel to follow
DASHBOARD_PASSWORD=               # BasicAuth password for the deployed dashboard (blank = no auth, local dev)
MEMEBOT_BURNER_PUBKEY=            # the ONE pubkey the bot may ever sign with; unset = live signing fails closed
